# ============================================
# NeuroLab 환경변수 템플릿
# 이 파일을 .env.local로 복사한 뒤 값을 채워 사용하세요
# cp .env.example .env.local
# ============================================

# --- Database ---
# PostgreSQL 연결 문자열 (Vercel 배포 시 Neon/Supabase 등 클라우드 DB 사용)
DATABASE_URL="postgresql://user:password@localhost:5432/payment_app"

# --- NextAuth ---
# 앱 URL (로컬: http://localhost:3000, 프로덕션: https://your-app.vercel.app)
NEXTAUTH_URL="http://localhost:3000"
# 시크릿 키 생성: openssl rand -base64 32
NEXTAUTH_SECRET=""

# --- Google OAuth ---
# Google Cloud Console > API 및 서비스 > 사용자 인증 정보 에서 생성
# 승인된 리디렉션 URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Polar.sh 결제 ---
# Polar 대시보드 > Settings > Developers > New Token 에서 생성
# Sandbox: https://sandbox.polar.sh / Production: https://polar.sh
POLAR_ACCESS_TOKEN=""
# Polar 대시보드 > Settings > Webhooks 에서 생성
POLAR_WEBHOOK_SECRET=""
# 결제 성공 후 리다이렉트 URL
POLAR_SUCCESS_URL="http://localhost:3000/checkout/success"
# sandbox 또는 production
POLAR_SERVER="sandbox"
# 판매할 상품 ID (Polar 대시보드에서 상품 생성 후 복사)
POLAR_PRODUCT_ID=""
